{
    "name": "brightcloudstudio/kinetics-submittal-export",
    "description": "Kinetics submittal export module for Contao 5",
    "type": "contao-bundle",
    "license": "LGPL-3.0-or-later",
    "authors": [
        {
            "name": "Bright Cloud Studio",
            "homepage": "https://brightcloudstudio.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "contao/core-bundle": "^5.3"
    },
    "require-dev": {
        "contao/manager-plugin": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "KineticsSubmittalExport\\": "src/"
        }
    },
    "extra": {
        "contao-manager-plugin": "KineticsSubmittalExport\\ContaoManager\\Plugin"
    },
    "minimum-stability": "dev"
}
